# Configurações de Ambiente - Desenvolvimento
# IMPORTANTE: Alterar valores em produção!

# Chave secreta para JWT
SECRET_KEY=change-me-in-prod

# Algoritmo JWT
ALGORITHM=HS256

# Expiração do token (em minutos)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# IDEALMENTE ISSO AQUI FICARIA EM UMA VARIÁVEL DE AMBIENTE SEPARADA, MAS PARA SIMPLICIDADE, VAMOS DEIXAR AQUI
# NO EM AMBIENTES CORPORATIVOS TERIAMOS COMO FERRAMENTAS O: AWS Secrets Manager, Azure Key Vault, HashiCorp Vault, entre outros.